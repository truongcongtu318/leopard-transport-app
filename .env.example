# ============================================================================
# LEOPARD APP — Environment Variables (Development)
# ============================================================================
# Copy file này thành .env:  cp .env.example .env
# .env đã được thêm vào .gitignore, KHÔNG commit file .env thật lên Git.
# ============================================================================

# --- PostgreSQL ---
POSTGRES_DB=leopard
POSTGRES_USER=leopard
POSTGRES_PASSWORD=change_this_password_in_production
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend API ---
BACKEND_PORT=8000
SECRET_KEY=change_this_to_random_64_chars_in_production
ENVIRONMENT=development

# --- Vietmap Maps API (free tier 2 tháng) ---
VIETMAP_API_KEY=your_vietmap_api_key_here

# --- OpenWeather API (free tier) ---
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Firebase ---
# Đường dẫn đến file JSON credentials của Firebase (tải từ Firebase Console)
FIREBASE_CREDENTIALS_PATH=./backend/config/firebase-credentials.json
FIREBASE_PROJECT_ID=leopard-transport

# --- OSRM (optional — local routing fallback) ---
OSRM_HOST=localhost
OSRM_PORT=5000

# --- Adminer (DB UI Tool) ---
ADMINER_PORT=8080
