# LEOPARD Environment Configuration
# Copy this to .env and fill in values

# API
API_BASE_URL=https://api.leopard.vn/api/v1
WS_BASE_URL=wss://api.leopard.vn/ws/v1

# Firebase (filled by google-services.json / GoogleService-Info.plist)
FIREBASE_PROJECT_ID=leopard-vn

# Google Maps (if needed for geocoding fallback)
GOOGLE_MAPS_API_KEY=

# Sentry (error monitoring)
SENTRY_DSN=
