# ── LEOPARD Backend Environment Variables ──────────────────────────────

# Database
LEOPARD_DATABASE_URL=postgresql+asyncpg://leopard:leopard_secret@localhost:5432/leopard_db

# Redis
LEOPARD_REDIS_URL=redis://localhost:6379/0

# JWT
LEOPARD_JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
LEOPARD_JWT_ALGORITHM=HS256
LEOPARD_JWT_EXPIRE_MINUTES=1440

# Firebase
LEOPARD_FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# Vietmap
LEOPARD_VIETMAP_API_KEY=your-vietmap-api-key

# OpenWeather
LEOPARD_OPENWEATHER_API_KEY=your-openweather-api-key

# Celery
LEOPARD_CELERY_BROKER_URL=redis://localhost:6379/1

# Uploads
LEOPARD_UPLOAD_DIR=./uploads

# Server
LEOPARD_DEBUG=true
LEOPARD_HOST=0.0.0.0
LEOPARD_PORT=8000
LEOPARD_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
